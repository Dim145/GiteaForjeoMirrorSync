# ---------------------------------------------------------------------------
# gitea-mirror-sync — configuration (all variables are prefixed with GMS_)
# Copy to .env (auto-loaded) or export in your environment.
# ---------------------------------------------------------------------------

# ===== Target: the local Gitea/Forgejo instance that holds the mirrors =====
GMS_TARGET_URL=https://gitea.example.com
GMS_TARGET_TOKEN=your_target_api_token
GMS_TARGET_OWNER=my-org            # user or org that will own the mirrors
# GMS_TARGET_OWNER_TYPE=auto       # auto | user | org   (default: auto)

# ===== Source: the forge to mirror from =====
GMS_SOURCE_TYPE=github             # github | gitlab | gitea | gitbucket
# GMS_SOURCE_URL=                  # optional for github/gitlab; required for gitea/gitbucket
                                   #   github default: https://api.github.com (GHE: https://ghe.host/api/v3)
                                   #   gitlab default: https://gitlab.com
                                   #   gitea:    https://gitea.src.com   (/api/v1 added automatically)
                                   #   gitbucket: https://gb.host/gitbucket (/api/v3 added automatically)
GMS_SOURCE_TOKEN=your_source_token
GMS_SOURCE_OWNER=my-github-user-or-org
# GMS_SOURCE_OWNER_TYPE=auto       # auto | user | org   (default: auto)

# ===== Scheduling (discovery cadence; Gitea handles the actual git sync) =====
# 6-field cron: "sec min hour day-of-month month day-of-week" (UTC).
# GMS_CRON=0 0 * * * *             # default: hourly at :00

# ===== Filters =====
# GMS_FILTER_INCLUDE=^prefix-      # regex: only repos whose name matches
# GMS_FILTER_EXCLUDE=-archive$     # regex: skip repos whose name matches
# GMS_FILTER_LIMIT=100             # cap the number of mirrors
# GMS_SKIP_FORKS=false             # default: false
# GMS_SKIP_ARCHIVED=false          # default: false
# GMS_INCLUDE_PRIVATE=true         # default: true (mirror private source repos too)

# ===== Mirror behavior =====
# GMS_MIRROR_INTERVAL=8h0m0s       # Gitea-side auto-sync interval (Go duration)
# GMS_MIRROR_PRIVATE=true          # default: true (force all mirrors private)
# GMS_TRIGGER_SYNC=false           # default: false (also POST mirror-sync each run)
# GMS_ROTATION_MODE=auto           # auto | recreate | warn   (default: auto)

# ===== State =====
# GMS_STATE_FILE=gms-state.json    # path to the persistent state file

# ===== Logging =====
# RUST_LOG=info                    # e.g. info,gitea_mirror_sync=debug
